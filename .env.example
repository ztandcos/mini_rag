# ═══════════════════════════════════════════════════════════════════════════
# Mini RAG — Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Configuration (OpenAI-compatible) ─────────────────────────────────
# Supports: DeepSeek, SiliconFlow, OpenAI, or any OpenAI-compatible provider
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Embedding Configuration (OpenAI-compatible) ───────────────────────────
# Supports any OpenAI-compatible embedding provider.
# Example for SiliconFlow + BAAI/bge-m3:
#   EMBEDDING_API_KEY=sf-your-key
#   EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
#   EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
