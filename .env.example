# ═══════════════════════════════════════════════════════════════════════════
# Mini RAG — Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Configuration (OpenAI-compatible) ─────────────────────────────────
# Supports: DeepSeek, OpenAI, or any OpenAI-compatible API provider
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Embedding Configuration (OpenAI-compatible) ───────────────────────────
# If using the same provider as LLM, you can duplicate the key.
# OpenAI's text-embedding-3-small is a good default for most use cases.
EMBEDDING_API_KEY=sk-your-openai-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
